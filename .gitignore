# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
.eggs/

# PyCharm
.idea/
*.iml

# VS Code
.vscode/

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/

# mypy / type checking
.mypy_cache/
.dmypy.json

# Jupyter
.ipynb_checkpoints/

# OS
.DS_Store
Thumbs.db
desktop.ini

# =============================================================================
# Project-specific
# =============================================================================

# Test / working directories created during conversion
work_dir/
_cc_tmp/

# Output VTPK files (large binaries, not meant for the repo)
*.vtpk

# Input MBTiles files (large binaries, keep out of repo)
*.mbtiles

# Temporary extraction folders
*/_alllayers/
*/p12/

# Logs
*.log
